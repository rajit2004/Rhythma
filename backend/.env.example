# =========================
# Required
# =========================
JWT_SECRET=your-secret-key-here

# =========================
# Firebase Service Account (choose one method)
# =========================
# Option 1: JSON string (paste the entire JSON content)
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...",...}'

# Option 2: Path to JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./path/to/service-account.json

# =========================
# Optional (for Gemini)
# =========================
GEMINI_API_KEY=your-gemini-api-key

# =========================
# Optional (for Twilio – SMS)
# =========================
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890